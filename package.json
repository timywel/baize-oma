{
  "name": "baize-oma",
  "version": "0.1.0",
  "description": "Baize slot adapter for @open-multi-agent/core. HTTP server wrapping OMA framework, exposed as BaizeSlot protocol. Vendored OMA under vendor/ for patch-package upgrade flow.",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "postinstall": "patch-package || true"
  },
  "keywords": [
    "baize",
    "slot",
    "multi-agent",
    "open-multi-agent",
    "http-server"
  ],
  "author": "Tim Ywel",
  "license": "MIT",
  "dependencies": {
    "@open-multi-agent/core": "1.8.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "patch-package": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
